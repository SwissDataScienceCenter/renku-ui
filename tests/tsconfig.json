{
  "include": ["node_modules/cypress", "cypress/**/*.ts", "cypress*.config.ts"],
  "compilerOptions": {
    "target": "es2020",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "types": ["cypress", "node", "cypress-file-upload"],
    "lib": ["es2020", "dom"],
    "skipLibCheck": true,
    "noEmit": true
  }
}
